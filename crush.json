{
  "$schema": "https://charm.land/crush.json",
  "models": {
    "large": {
      "model": "glm-5",
      "provider": "tx_token_plan"
    },
    "small": {
      "model": "minimax-m2.5",
      "provider": "tx_token_plan"
    }
  },
  "providers": {
    "ollama": {
      "name": "Ollama",
      "base_url": "http://localhost:11434/v1/",
      "type": "openai-compat",
      "models": [
        {
          "name": "GLM-4.7 Flash",
          "id": "glm-4.7-flash:q4_K_M",
          "context_window": 200000,
          "default_max_tokens": 8000
        },
        {
          "name": "Qwen 3 Coder 30B",
          "id": "qwen3-coder:30b-a3b-q4_K_M",
          "context_window": 256000,
          "default_max_tokens": 20000
        },
        {
          "name": "Qwen 3 4B Thinking",
          "id": "qwen3:4b-thinking-2507-q4_K_M",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "Qwen 3 4B Instruct",
          "id": "qwen3:4b-instruct-2507-q4_K_M",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "Qwen 3 VL 8B",
          "id": "qwen3-vl:8b-thinking-q4_K_M",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "Qwen 3.5 4B",
          "id": "qwen3.5:4b-q4_K_M",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "Qwen 3.5 35B",
          "id": "qwen3.5:35b-a3b-q4_K_M",
          "context_window": 256000,
          "default_max_tokens": 20000
        },
        {
          "name": "Qwen 3.5 9B",
          "id": "qwen3.5:9b",
          "context_window": 128000,
          "default_max_tokens": 10000
        }
      ]
    },
    "tx_token_plan": {
      "name": "Tencent",
      "base_url": "https://api.lkeap.cloud.tencent.com/plan/v3",
      "type": "openai-compat",
      "api_key": "${TX_TOKEN_PLAN_API_KEY}",
      "models": [
        {
          "name": "TxMiniMax-M2.5",
          "id": "minimax-m2.5",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "TxKimi-K2.5",
          "id": "kimi-k2.5",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "TxGLM-5",
          "id": "glm-5",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "hunyuan-turbos",
          "id": "hunyuan-turbos",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "Tencent HY 2.0 Think",
          "id": "hunyuan-2.0-thinking",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "Tencent HY 2.0 Instruct",
          "id": "hunyuan-2.0-instruct",
          "context_window": 128000,
          "default_max_tokens": 10000
        },
        {
          "name": "HY T1",
          "id": "hunyuan-t1",
          "context_window": 128000,
          "default_max_tokens": 10000
        }
      ]
    }
  },
  "lsp": {
    "gopls": {
      "options": {
        "gofumpt": true,
        "codelenses": {
          "gc_details": true,
          "generate": true,
          "run_govulncheck": true,
          "test": true,
          "tidy": true,
          "upgrade_dependency": true
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        },
        "analyses": {
          "nilness": true,
          "unusedparams": true,
          "unusedvariable": true,
          "unusedwrite": true,
          "useany": true
        },
        "staticcheck": true,
        "directoryFilters": [
          "-.git",
          "-node_modules"
        ],
        "semanticTokens": true
      }
    }
  }
}